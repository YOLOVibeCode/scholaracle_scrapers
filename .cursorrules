## Mandates (ENFORCE STRICTLY)

### M1: TDD — Red-Green-Refactor

Every feature, scraper, and bug fix MUST start with a failing test.

**Workflow:**
1. **RED** — Write a test that fails (describes desired behavior)
2. **GREEN** — Write the minimum code to make it pass
3. **REFACTOR** — Clean up while keeping tests green

```typescript
// ❌ REJECT — implementing before testing
export function normalizeStatus(raw: string): string {
  if (raw.includes('miss')) return 'missing';
  return 'unknown';
}
// then writing tests after

// ✅ REQUIRE — test first, implement second
// Step 1: Write the test (RED)
describe('normalizeStatus', () => {
  it('should normalize "Missing" to "missing"', () => {
    expect(normalizeStatus('Missing')).toBe('missing');
  });
  it('should normalize "Submitted Late" to "late"', () => {
    expect(normalizeStatus('Submitted Late')).toBe('late');
  });
  it('should return "unknown" for unrecognized status', () => {
    expect(normalizeStatus('foobar')).toBe('unknown');
  });
});
// Step 2: Implement to pass (GREEN)
// Step 3: Refactor if needed
```

### M2: Interface Segregation (ISP)

Interfaces must be small and focused on a single concern. No god interfaces.

```typescript
// ❌ REJECT — god interface
interface IScraper {
  initialize(config: IScraperConfig): Promise<void>;
  authenticate(): Promise<{ success: boolean }>;
  scrape(): Promise<Record<string, unknown>>;
  transform(raw: Record<string, unknown>): ISlcDeltaOp[];
  cleanup(): Promise<void>;
  validate(envelope: ISlcIngestEnvelopeV1): EnvelopeValidationReport;
  upload(envelope: ISlcIngestEnvelopeV1): Promise<UploadResult>;
  generate(prompt: string): Promise<string>;
  troubleshoot(error: string): Promise<string>;
}

// ✅ REQUIRE — granular interfaces per concern
interface IScraperLifecycle {
  initialize(config: IScraperConfig): Promise<void>;
  authenticate(): Promise<{ success: boolean; message?: string }>;
  scrape(): Promise<Record<string, unknown>>;
  cleanup(): Promise<void>;
}

interface IDataTransformer<TRaw = Record<string, unknown>> {
  transform(raw: TRaw, ctx: TransformContext): ISlcDeltaOp[];
}

interface IEnvelopeValidator {
  validate(envelope: ISlcIngestEnvelopeV1): EnvelopeValidationReport;
}

interface IEnvelopeUploader {
  upload(envelope: ISlcIngestEnvelopeV1): Promise<UploadResult>;
}
```

### M3: Three-File Scraper Pattern

Every platform scraper MUST have exactly three files:

```
src/scrapers/[platform]/
├── metadata.json              # Scraper identity + capabilities
├── [platform]-scraper.ts      # Playwright automation (extends BaseScraper)
└── [platform]-transformer.ts  # Raw data → ISlcDeltaOp[] (pure function)
```

```typescript
// ❌ REJECT — mixing scraping and transformation in one file
export class FooScraper extends BaseScraper {
  async scrape() { /* browser logic */ }
  transform(raw) {
    // 200 lines of data mapping mixed with scraper class
  }
}

// ✅ REQUIRE — separate transformer file
// foo-scraper.ts
export class FooScraper extends BaseScraper {
  async scrape() { /* browser logic only */ }
  transform(raw: Record<string, unknown>) {
    return transformFooExtract(raw as IFooBrowserExtract, this.getContext());
  }
}

// foo-transformer.ts (pure function, easy to test)
export function transformFooExtract(
  extract: IFooBrowserExtract,
  ctx: TransformContext,
): ISlcDeltaOp[] { /* mapping logic */ }
```

### M4: TransformContext Pattern

All transformers receive a `TransformContext` — never hardcode key fields.

```typescript
// ❌ REJECT — hardcoded provider/adapterId in transformer
ops.push({
  op: 'upsert', entity: 'course',
  key: { provider: 'canvas', adapterId: 'com.instructure.canvas', externalId: id },
  observedAt: now,
  record: { title },
});

// ✅ REQUIRE — use TransformContext
export interface TransformContext {
  provider: string;
  adapterId: string;
  studentExternalId: string;
  institutionExternalId: string;
}

ops.push({
  op: 'upsert', entity: 'course',
  key: { ...baseKey, externalId: id },  // baseKey derived from ctx
  observedAt: now,
  record: { title },
});
```

### M5: Envelope Validation

All envelopes MUST be validated before upload.

```typescript
// ❌ REJECT — uploading without validation
const envelope = scraper.assembleEnvelope(ops);
await uploader.upload(envelope);

// ✅ REQUIRE — validate first
import { validateEnvelope } from '../core/validator';

const envelope = scraper.assembleEnvelope(ops);
const report = validateEnvelope(envelope);
if (!report.passed) {
  throw new Error(`Envelope invalid: ${report.errorCount} errors`);
}
await uploader.upload(envelope);
```

### M6: BaseScraper Lifecycle

All scrapers MUST extend `BaseScraper` from `src/core/base-scraper.ts` and implement the full lifecycle.

```typescript
// ❌ REJECT — standalone scraper without BaseScraper
export async function scrapeFoo(config) {
  const browser = await chromium.launch();
  // ... all logic inline
}

// ✅ REQUIRE — extend BaseScraper
import { BaseScraper } from '../../core/base-scraper';

export class FooScraper extends BaseScraper {
  get metadata(): IScraperMetadata { /* ... */ }
  async initialize(config: IScraperConfig): Promise<void> { /* launch browser */ }
  async authenticate(): Promise<{ success: boolean; message?: string }> { /* login */ }
  async scrape(): Promise<Record<string, unknown>> { /* extract data */ }
  transform(rawData: Record<string, unknown>): ISlcDeltaOp[] { /* delegate to transformer */ }
  async cleanup(): Promise<void> { /* close browser */ }
}
```

### M7: Credential Safety

Never log, hardcode, or commit credentials. Never call real portals in tests.

```typescript
// ❌ REJECT — hardcoded credentials
const page = await browser.newPage();
await page.goto('https://real-school.instructure.com');
await page.fill('#username', 'student@school.edu');
await page.fill('#password', 'realPassword123');

// ✅ REQUIRE — credentials from config
await page.goto(this.config!.credentials.baseUrl);
if (this.config!.credentials.username) {
  await page.fill('#username', this.config!.credentials.username);
}

// ✅ REQUIRE — mock Playwright in tests
jest.mock('playwright', () => ({
  chromium: { launch: jest.fn().mockResolvedValue(mockBrowser) },
}));
```

### M8: Contract Types

All entity shapes and envelope types come from `src/core/types.ts`. No local duplicates.

```typescript
// ❌ REJECT — local type definitions
interface Assignment { title: string; dueDate: string; }
interface Course { name: string; code: string; }

// ✅ REQUIRE — import from core types
import type {
  ISlcAssignment,
  ISlcCourse,
  ISlcDeltaOp,
  ISlcIngestEnvelopeV1,
  SlcEntityType,
} from '../../core/types';
```

### M9: Test Factory Pattern

Use factory helpers for test data. Colocate tests next to source files.

```typescript
// ❌ REJECT — inline test data with magic values
it('should transform courses', () => {
  const ops = transformCanvasExtract({
    user: 'Emma', courses: [{ id: '1', name: 'Math', courseCode: 'M-1',
    url: 'https://canvas.com/1', assignments: [], modules: [], files: [] }],
    toDoItems: [], upcomingEvents: [], announcements: [], timestamp: '2026-02-16T12:00:00Z',
  }, { provider: 'canvas', adapterId: 'com.instructure.canvas',
    studentExternalId: 'stu-1', institutionExternalId: 'inst-1' });
  // ...
});

// ✅ REQUIRE — factory helpers + shared context
const ctx: TransformContext = {
  provider: 'canvas',
  adapterId: 'com.instructure.canvas',
  studentExternalId: 'stu-emma',
  institutionExternalId: 'inst-ldisd',
};

function makeExtract(overrides?: Partial<ICanvasBrowserExtract>): ICanvasBrowserExtract {
  return { user: 'Emma Lewis', courses: [/* defaults */], ...overrides };
}

it('should transform courses', () => {
  const ops = transformCanvasExtract(makeExtract(), ctx);
  // clean, readable assertions
});
```

